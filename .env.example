# Public environment variables
NEXT_PUBLIC_APP_URL=https://rampchat.onrender.com

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=YOUR_PROJECT_ID

NEXT_PUBLIC_APPWRITE_DATABASE_ID=rampchat_main
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=rc_profiles
NEXT_PUBLIC_APPWRITE_CONVERSATIONS_COLLECTION_ID=rc_conversations
NEXT_PUBLIC_APPWRITE_MESSAGES_COLLECTION_ID=rc_messages

NEXT_PUBLIC_APPWRITE_PROJECT_NAME=RampChat
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
NEXT_PUBLIC_OWNER_EMAIL=YOUR_EMAIL

# Public collection IDs (used on the client side)
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_APPLICATIONS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_AUDIT_LOGS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_FOLLOWS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_MEMBERSHIPS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_NOTIFICATIONS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_ORGS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_POSTS_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_POST_LIKES_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_POST_REPLIES_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_RECRUITMENT_COLLECTION_ID=YOUR_VALUE
NEXT_PUBLIC_APPWRITE_REPORTS_COLLECTION_ID=YOUR_VALUE

# Optional: Cloudinary unsigned upload preset for client‑side uploads
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=YOUR_UPLOAD_PRESET

# Private environment variables
APPWRITE_API_KEY=YOUR_API_KEY

APPWRITE_DATABASE_ID=rampchat_main

APPWRITE_PROFILES_COLLECTION_ID=rc_profiles
APPWRITE_CONVERSATIONS_COLLECTION_ID=rc_conversations
APPWRITE_MESSAGES_COLLECTION_ID=rc_messages

APPWRITE_USERS_COLLECTION_ID=YOUR_VALUE
APPWRITE_APPLICATIONS_COLLECTION_ID=YOUR_VALUE
APPWRITE_AUDIT_LOGS_COLLECTION_ID=YOUR_VALUE
APPWRITE_FOLLOWS_COLLECTION_ID=YOUR_VALUE
APPWRITE_MEMBERSHIPS_COLLECTION_ID=YOUR_VALUE
APPWRITE_NOTIFICATIONS_COLLECTION_ID=YOUR_VALUE
APPWRITE_ORGS_COLLECTION_ID=YOUR_VALUE
APPWRITE_POSTS_COLLECTION_ID=YOUR_VALUE
APPWRITE_POST_LIKES_COLLECTION_ID=YOUR_VALUE
APPWRITE_POST_REPLIES_COLLECTION_ID=YOUR_VALUE
APPWRITE_RECRUITMENT_COLLECTION_ID=YOUR_VALUE
APPWRITE_REPORTS_COLLECTION_ID=YOUR_VALUE

# Cloudinary configuration
CLOUDINARY_API_KEY=YOUR_API_KEY
CLOUDINARY_API_SECRET=YOUR_API_SECRET
CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
CLOUDINARY_FOLDER=YOUR_FOLDER

# App configuration
NODE_ENV=production
PORT=10000

OWNER_EMAIL=YOUR_EMAIL
OWNER_PASSWORD=YOUR_PASSWORD